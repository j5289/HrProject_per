<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.itwillbs.mapper.MemberMapper">

	<select id="getTime" resultType="string">
		select now()
	</select>

	<!-- 회원가입 -->
	<!-- <insert id="insertMember"> 
		insert into EMPLOYEE (emp_id, emp_name, emp_pw, emp_phone, emp_email, emp_address, dep_name, pos_id, rank_id)
		values(#{empId}, #{empName}, #{empPw}, #{empPhone}, #{empEmail}, #{empAddress}, #{depName}, #{posId}, #{rankId}) 
	</insert> -->
	<!-- 회원가입 -->

	<!-- 로그인 체크 -->
	<select id="loginCheck" resultType="com.itwill.domain.MemberVO">
		select * from EMPLOYEE
		where emp_id=#{empId} and emp_pw=#{empPw}
	</select>
	<!-- 로그인 체크 -->

	<!-- 내정보 보기 -->
	<select id="getMemberInfo"
		resultType="com.itwill.domain.MemberVO">
		select * from EMPLOYEE
		where emp_id = #{empId}
	</select>
	<!-- 내정보 보기 -->

	<!-- 회원정보 수정 -->
	<update id="updateMember">
		update EMPLOYEE
		set emp_name = #{empName},
		emp_modify_date = now()
		where emp_id = #{empId} and emp_pw = #{empPw}
	</update>
	<!-- 회원정보 수정 -->

	<!-- 회원정보 삭제 -->
	<delete id="deleteMember">
		delete from EMPLOYEE
		where emp_id=#{empId} and emp_pw=#{empPw}
	</delete>
	<!-- 회원정보 삭제 -->

	<!-- 회원 전체목록 조회 -->
	<select id="getMemberList"
		resultType="com.itwill.domain.MemberVO">
		select * from EMPLOYEE
	</select>
	<!-- 회원 전체목록 조회 -->

	<!-- 회원번호로 회원 조회 -->
	<select id="selectByEmpId" parameterType="string"
		resultType="com.itwill.domain.MemberVO">
		SELECT * FROM EMPLOYEE WHERE emp_id = #{empId}
	</select>
	<!-- 회원번호로 회원 조회 -->

	<!-- 비밀번호로 회원정보 수정 -->
	<update id="updatePassword" parameterType="map">
		UPDATE EMPLOYEE
		SET emp_pw = #{newPassword},
		emp_modifydate = NOW()
		WHERE emp_id = #{empId}
		LIMIT 1
	</update>

</mapper>