<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.itwill.employee.persistence.CalendarDAO">

    <!-- 일정 등록 -->
    <insert id="insertCalendar" parameterType="com.itwill.employee.domain.CalendarVO">
        INSERT INTO CALENDAR (cal_date, cal_title)
        VALUES (#{calDate}, #{calTitle})
    </insert>

    <!-- 일정 목록 조회 -->
    <select id="getAllCalendar" resultType="com.itwill.employee.domain.CalendarVO">
        SELECT cal_id, cal_date, cal_title
        FROM CALENDAR
        ORDER BY cal_date ASC
    </select>

</mapper>
